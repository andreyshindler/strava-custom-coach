STRAVA_TELEGRAM_BOT_TOKEN=123456:AABBcc...
PUBLIC_URL=https://yourserver.com
FLASK_SECRET=change-me-use-secrets-token-hex-32
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_USER=admin
ADMIN_PASSWORD=yourpassword
WEBHOOK_VERIFY_TOKEN=strava-coach

# Absolute host path to this repo — used by the web service when spawning per-user containers
# On Linux VPS: /opt/strava-custom-coach
CODE_DIR=/opt/strava-custom-coach

# Port for the web service.
# Production Docker: 5000 (or omit — 5000 is the default)
# Branch testing alongside production systemd: use 5001 to avoid conflict
WEB_PORT=5001
